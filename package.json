{
  "name": "portfolio",
  "version": "1.3.1",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "check:resume": "node scripts/check-resume-keys.mjs",
    "resume:seal": "node scripts/seal-resume.mjs",
    "resume:reveal": "node scripts/reveal-resume.mjs",
    "resume:password": "node scripts/print-resume-password.mjs",
    "analyze": "ANALYZE=true next build",
    "commit": "cz",
    "release:dry-run": "semantic-release --dry-run",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@sentry/nextjs": "^10.65.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.7.0",
    "resend": "^6.17.1",
    "shadcn": "^4.13.0",
    "simple-icons": "^16.25.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@next/bundle-analyzer": "^16.2.10",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
